<% if record.errors.any? %>
  <div class="rounded-md bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 p-4 mb-6">
    <h3 class="text-sm font-semibold text-red-700 dark:text-red-300 mb-2">
      <%= pluralize(record.errors.count, "error") %> prevented this from being saved:
    </h3>
    <ul class="list-disc list-inside text-sm text-red-600 dark:text-red-400 space-y-1">
      <% record.errors.full_messages.each do |msg| %>
        <li><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>
