<div data-controller="bulk-play-form"
     data-bulk-play-form-initial-plays-value="<%= (local_assigns[:submitted_plays] || []).to_json %>">

  <%# ── Meta form (not submitted) ──────────────────────────────────────── %>
  <div data-meta-participants-section class="bg-gray-50 dark:bg-gray-800/50 border border-gray-200 dark:border-gray-700 rounded-lg p-5 mb-6 space-y-4">
    <p class="text-sm font-semibold text-gray-700 dark:text-gray-300">Common attributes <span class="font-normal text-gray-500 dark:text-gray-400">(applied to all plays; leave blank to set per play)</span></p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Game</label>
        <select data-bulk-play-form-target="metaGame"
                data-action="change->bulk-play-form#metaChanged"
                class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
          <option value="">— Set for all plays —</option>
          <% games.each do |game| %>
            <option value="<%= game.id %>"><%= game.name %></option>
          <% end %>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Date</label>
        <input type="date"
               data-bulk-play-form-target="metaDate"
               data-action="change->bulk-play-form#metaChanged"
               class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Location</label>
        <select data-bulk-play-form-target="metaLocation"
                data-action="change->bulk-play-form#metaChanged"
                class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
          <option value="">— None —</option>
          <% locations.each do |location| %>
            <option value="<%= location.id %>"><%= location.name %></option>
          <% end %>
        </select>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</label>
        <textarea data-bulk-play-form-target="metaNotes"
                  data-action="input->bulk-play-form#metaChanged"
                  rows="1"
                  placeholder="Shared notes…"
                  class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"></textarea>
      </div>
    </div>

    <div>
      <div class="flex items-center justify-between mb-2">
        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300">Participants</label>
        <button type="button"
                data-action="bulk-play-form#addMetaParticipant"
                class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline">
          + Add Participant
        </button>
      </div>
      <div data-bulk-play-form-target="metaParticipants" class="space-y-2"></div>
    </div>
  </div>

  <%# Meta participant row template (never submitted — no name attributes) %>
  <template data-bulk-play-form-target="metaParticipantTemplate">
    <div data-meta-participant-row class="flex items-center gap-3 p-3 bg-white dark:bg-gray-800 rounded-md border border-gray-200 dark:border-gray-700">
      <div class="flex-1">
        <select data-action="change->bulk-play-form#metaChanged"
                class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
          <option value="">— Player —</option>
          <% players.each do |player| %>
            <option value="<%= player.id %>" data-name="<%= player.name %>"><%= player.name %></option>
          <% end %>
        </select>
      </div>
      <button type="button"
              data-action="bulk-play-form#removeMetaParticipant"
              class="p-1.5 rounded text-gray-400 hover:text-red-600 dark:hover:text-red-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors flex-shrink-0"
              title="Remove">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
  </template>

  <%# ── Play entries form (submitted) ──────────────────────────────────── %>
  <%= form_tag bulk_create_plays_path, method: :post, class: "space-y-4" do %>
    <div data-bulk-play-form-target="playsContainer" class="space-y-4"></div>

    <%# Play entry template %>
    <template data-bulk-play-form-target="playTemplate">
      <div data-bulk-play-form-target="play"
           data-play-participant-index="0"
           class="border border-gray-200 dark:border-gray-700 rounded-lg p-4 space-y-3 bg-white dark:bg-gray-900">

        <div class="flex items-center justify-between">
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300">Play <span data-play-number></span></p>
          <button type="button"
                  data-action="bulk-play-form#removePlay"
                  class="text-sm text-gray-400 hover:text-red-600 dark:hover:text-red-400 hover:underline">
            Remove
          </button>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <%# Game %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Game</label>
            <div data-editable="game">
              <select name="plays[PLAY_IDX][game_id]"
                      class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                <option value="">— Select a game —</option>
                <% games.each do |game| %>
                  <option value="<%= game.id %>"><%= game.name %></option>
                <% end %>
              </select>
            </div>
            <div data-locked="game" class="hidden">
              <span class="block px-3 py-2 text-sm text-gray-900 dark:text-white bg-gray-100 dark:bg-gray-700 rounded-md border border-gray-200 dark:border-gray-600" data-display="game"></span>
              <input type="hidden" name="plays[PLAY_IDX][game_id]" data-input="game">
            </div>
          </div>

          <%# Date %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Date</label>
            <div data-editable="date">
              <input type="date" name="plays[PLAY_IDX][date]"
                     class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
            </div>
            <div data-locked="date" class="hidden">
              <span class="block px-3 py-2 text-sm text-gray-900 dark:text-white bg-gray-100 dark:bg-gray-700 rounded-md border border-gray-200 dark:border-gray-600" data-display="date"></span>
              <input type="hidden" name="plays[PLAY_IDX][date]" data-input="date">
            </div>
          </div>

          <%# Location %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Location</label>
            <div data-editable="location">
              <select name="plays[PLAY_IDX][location_id]"
                      class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                <option value="">— None —</option>
                <% locations.each do |location| %>
                  <option value="<%= location.id %>"><%= location.name %></option>
                <% end %>
              </select>
            </div>
            <div data-locked="location" class="hidden">
              <span class="block px-3 py-2 text-sm text-gray-900 dark:text-white bg-gray-100 dark:bg-gray-700 rounded-md border border-gray-200 dark:border-gray-600" data-display="location"></span>
              <input type="hidden" name="plays[PLAY_IDX][location_id]" data-input="location">
            </div>
          </div>

          <%# Notes %>
          <div>
            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</label>
            <div data-editable="notes">
              <textarea name="plays[PLAY_IDX][notes]" rows="1"
                        class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500"></textarea>
            </div>
            <div data-locked="notes" class="hidden">
              <span class="block px-3 py-2 text-sm text-gray-900 dark:text-white bg-gray-100 dark:bg-gray-700 rounded-md border border-gray-200 dark:border-gray-600 whitespace-pre-wrap" data-display="notes"></span>
              <input type="hidden" name="plays[PLAY_IDX][notes]" data-input="notes">
            </div>
          </div>
        </div>

        <%# Participants %>
        <div>
          <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-2">Participants</p>

          <%# Locked meta-participant rows (player fixed, score/winner editable) %>
          <div data-field="meta-participants" class="space-y-2 mb-2"></div>

          <%# Per-play editable participants (shown when no meta participants) %>
          <div data-field="extra-participants" class="space-y-2">
            <div data-bulk-play-form-target="playParticipantsContainer" class="space-y-2"></div>
            <button type="button"
                    data-action="bulk-play-form#addPlayParticipant"
                    class="text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline">
              + Add Participant
            </button>
            <template data-bulk-play-form-target="playParticipantTemplate">
              <div data-play-participant-row class="flex items-center gap-3 p-3 bg-gray-50 dark:bg-gray-800 rounded-md border border-gray-200 dark:border-gray-700">
                <div class="flex-1">
                  <select name="plays[PLAY_IDX][play_participants_attributes][PART_IDX][player_id]"
                          class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                    <option value="">— Player —</option>
                    <% players.each do |player| %>
                      <option value="<%= player.id %>"><%= player.name %></option>
                    <% end %>
                  </select>
                </div>
                <div class="w-24">
                  <input type="number" name="plays[PLAY_IDX][play_participants_attributes][PART_IDX][score]"
                         placeholder="Score"
                         class="block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500">
                </div>
                <label class="flex items-center gap-1.5 text-sm text-gray-700 dark:text-gray-300 whitespace-nowrap">
                  <input type="checkbox" name="plays[PLAY_IDX][play_participants_attributes][PART_IDX][winner]" value="1"
                         class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                  Winner
                </label>
                <button type="button"
                        data-action="bulk-play-form#removePlayParticipant"
                        class="p-1.5 rounded text-gray-400 hover:text-red-600 dark:hover:text-red-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors flex-shrink-0"
                        title="Remove">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                  </svg>
                </button>
              </div>
            </template>
          </div>
        </div>

      </div>
    </template>

    <div class="flex items-center gap-4 pt-2">
      <button type="button"
              data-action="bulk-play-form#addPlay"
              class="rounded-md border border-indigo-600 text-indigo-600 dark:text-indigo-400 dark:border-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 text-sm font-semibold py-2 px-4 transition-colors">
        + Add Play
      </button>
      <button type="submit"
              class="rounded-md bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2 px-4 transition-colors cursor-pointer">
        Record Plays
      </button>
      <%= link_to "Cancel", plays_path,
          class: "text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
    </div>
  <% end %>

</div>
