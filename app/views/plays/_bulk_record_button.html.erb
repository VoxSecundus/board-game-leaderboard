<% if no_games %>
  <button disabled
          class="rounded-md border border-indigo-300 dark:border-indigo-800 text-indigo-300 dark:text-indigo-800 text-sm font-semibold py-2 px-4 opacity-50 cursor-not-allowed"
          title="Add a game before recording plays">
    Bulk Record
  </button>
<% else %>
  <%= link_to "Bulk Record", bulk_new_plays_path,
      class: "rounded-md border border-indigo-600 text-indigo-600 dark:text-indigo-400 dark:border-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/30 text-sm font-semibold py-2 px-4 transition-colors" %>
<% end %>
