<% if @no_games %>
  <button disabled
          class="rounded-md bg-indigo-300 dark:bg-indigo-900 text-white text-sm font-semibold py-2 px-4 opacity-50 cursor-not-allowed"
          title="Add a game before recording a play">
    Record Play
  </button>
<% else %>
  <%= link_to "Record Play", new_play_path,
      class: "rounded-md bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2 px-4 transition-colors" %>
<% end %>
