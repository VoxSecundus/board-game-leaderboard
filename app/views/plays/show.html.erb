<% content_for :title, @play.date&.strftime("%d %b %Y") || "Play ##{@play.id}" %>
<% breadcrumbs(["Home", root_path], ["Plays", plays_path], [@play.date&.strftime("%d %b %Y") || "Play ##{@play.id}", nil]) %>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 max-w-2xl">
  <div class="flex items-start justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
        <%= link_to @play.game.name, game_path(@play.game),
            class: "hover:text-indigo-600 dark:hover:text-indigo-400" %>
      </h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        <% if @play.date %>
          Played <%= @play.date.strftime("%d %b %Y") %>
        <% else %>
          Date unknown
        <% end %>
        <% if @play.location %>
          · <%= @play.location.name %>
        <% end %>
      </p>
    </div>
    <div class="flex items-center gap-3 flex-shrink-0">
      <%= link_to "Edit", edit_play_path(@play),
          class: "text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline" %>
      <%= button_to "Delete", play_path(@play), method: :delete,
          data: { turbo_confirm: "Delete this play?" },
          class: "text-sm font-medium text-red-600 dark:text-red-400 hover:underline bg-transparent border-0 cursor-pointer p-0" %>
    </div>
  </div>

  <% if @play.notes.present? %>
    <div class="mb-6">
      <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Notes</p>
      <p class="text-sm text-gray-600 dark:text-gray-400"><%= @play.notes %></p>
    </div>
  <% end %>

  <% if @play.play_participants.any? %>
    <div>
      <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-3">Players</p>
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700 text-sm">
        <thead>
          <tr>
            <th class="pb-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Player</th>
            <th class="pb-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Score</th>
            <th class="pb-2 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Result</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
          <% @play.play_participants.includes(:player).each do |pp| %>
            <tr>
              <td class="py-3">
                <div class="flex items-center gap-2">
                  <%= player_avatar(pp.player) %>
                  <span class="text-gray-900 dark:text-white"><%= pp.player.name %></span>
                </div>
              </td>
              <td class="py-3 text-gray-600 dark:text-gray-400">
                <%= pp.score || "—" %>
              </td>
              <td class="py-3">
                <% if pp.winner? %>
                  <span class="inline-flex items-center gap-1 text-amber-600 dark:text-amber-400 font-medium">
                    <span>★</span> Winner
                  </span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
