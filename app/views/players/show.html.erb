<% content_for :title, @player.name %>
<% breadcrumbs(["Home", root_path], ["Players", players_path], [@player.name, nil]) %>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 max-w-2xl">
  <div class="flex items-start gap-6">
    <div class="flex-shrink-0">
      <%= player_avatar(@player, size: :lg) %>
    </div>
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @player.name %></h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Added <%= @player.created_at.to_date %></p>
    </div>
    <div class="flex items-center gap-3 flex-shrink-0">
      <%= link_to "Edit", edit_player_path(@player),
          class: "text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline" %>
      <%= button_to "Delete", player_path(@player), method: :delete,
          data: { turbo_confirm: "Delete #{@player.name}?" },
          class: "text-sm font-medium text-red-600 dark:text-red-400 hover:underline bg-transparent border-0 cursor-pointer p-0" %>
    </div>
  </div>
</div>
