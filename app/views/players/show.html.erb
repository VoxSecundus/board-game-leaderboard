<% content_for :title, @player.name %>
<% breadcrumbs(["Home", root_path], ["Players", players_path], [@player.name, nil]) %>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 max-w-2xl">
  <div class="flex items-start gap-6">
    <div class="flex-shrink-0">
      <%= player_avatar(@player, size: :lg) %>
    </div>
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @player.name %></h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Added <%= @player.created_at.to_date %></p>
    </div>
    <div class="flex items-center gap-3 flex-shrink-0">
      <%= link_to "Edit", edit_player_path(@player),
          class: "text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline" %>
      <%= button_to "Delete", player_path(@player), method: :delete,
          data: { turbo_confirm: "Delete #{@player.name}?" },
          class: "text-sm font-medium text-red-600 dark:text-red-400 hover:underline bg-transparent border-0 cursor-pointer p-0" %>
    </div>
  </div>
</div>

<div class="mt-8">
  <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Play History</h2>
  <% if @plays.empty? %>
    <p class="text-sm text-gray-500 dark:text-gray-400">No plays recorded for this player yet.</p>
  <% else %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-800">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              <%= sortable_link("date", "Date") %>
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Game</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              <%= sortable_link("location", "Location") %>
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Players</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Winner(s)</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Notes</th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
          <% @plays.each do |play| %>
            <%= render "plays/history_row", play: play, show_game: true, highlight_player: @player %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
