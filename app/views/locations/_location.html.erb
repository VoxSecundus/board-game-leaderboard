<div data-controller="navigate" data-navigate-url-value="<%= location_path(location) %>"
     data-action="click->navigate#go"
     class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden hover:shadow-md transition-shadow cursor-pointer">
  <div class="p-4">
    <div class="flex items-start justify-between gap-2">
      <div class="min-w-0">
        <%= link_to location.name, location_path(location),
            class: "text-base font-bold text-gray-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 leading-tight" %>
        <% if location.latitude.present? && location.longitude.present? %>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">
            <%= number_with_precision(location.latitude, precision: 4) %>,
            <%= number_with_precision(location.longitude, precision: 4) %>
          </p>
        <% end %>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Added <%= location.created_at.to_date %></p>
      </div>

      <div class="flex items-center gap-1 flex-shrink-0">
        <% if location.latitude.present? && location.longitude.present? %>
          <% map_query = { mlat: location.latitude.to_s("F"), mlon: location.longitude.to_s("F") }.to_query %>
          <%= link_to "https://www.openstreetmap.org/?#{map_query}",
              target: "_blank", rel: "noopener noreferrer",
              title: "View on map",
              class: "p-1.5 rounded text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          <% end %>
        <% end %>
        <%= link_to edit_location_path(location),
            title: "Edit",
            class: "p-1.5 rounded text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
        <% end %>
        <%= button_to location_path(location), method: :delete,
            title: "Delete",
            data: { turbo_confirm: "Delete #{location.name}?" },
            class: "p-1.5 rounded text-gray-400 hover:text-red-600 dark:hover:text-red-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors bg-transparent border-0 cursor-pointer" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</div>
