<%= render "shared/errors", record: location %>

<%= form_with model: location, class: "space-y-6" do |f| %>
  <div>
    <%= f.label :name, "Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_field :name,
        autofocus: location.new_record?,
        class: "block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div class="grid grid-cols-2 gap-4">
    <div>
      <%= f.label :latitude, "Latitude", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.number_field :latitude,
          step: "any", placeholder: "e.g. 51.5074",
          class: "block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
    <div>
      <%= f.label :longitude, "Longitude", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
      <%= f.number_field :longitude,
          step: "any", placeholder: "e.g. -0.1278",
          class: "block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    </div>
  </div>
  <p class="text-xs text-gray-500 dark:text-gray-400 -mt-4">Leave both blank if unknown.</p>

  <div class="flex items-center gap-3">
    <%= f.submit location.new_record? ? "Create Location" : "Update Location",
        class: "rounded-md bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2 px-4 transition-colors cursor-pointer" %>
    <%= link_to "Cancel",
        location.new_record? ? locations_path : location_path(location),
        class: "text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
  </div>
<% end %>
