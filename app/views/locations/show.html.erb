<% content_for :title, @location.name %>
<% breadcrumbs(["Home", root_path], ["Locations", locations_path], [@location.name, nil]) %>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 max-w-2xl">
  <div class="flex items-start justify-between">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @location.name %></h1>
      <% if @location.latitude.present? && @location.longitude.present? %>
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">
          <%= number_with_precision(@location.latitude, precision: 6) %>,
          <%= number_with_precision(@location.longitude, precision: 6) %>
          &nbsp;·&nbsp;
          <%= link_to "View on map",
              "https://www.openstreetmap.org/?mlat=#{@location.latitude}&mlon=#{@location.longitude}",
              target: "_blank", rel: "noopener noreferrer",
              class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
        </p>
      <% end %>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Added <%= @location.created_at.to_date %></p>
    </div>
    <div class="flex items-center gap-3 flex-shrink-0">
      <%= link_to "Edit", edit_location_path(@location),
          class: "text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline" %>
      <%= button_to "Delete", location_path(@location), method: :delete,
          data: { turbo_confirm: "Delete #{@location.name}?" },
          class: "text-sm font-medium text-red-600 dark:text-red-400 hover:underline bg-transparent border-0 cursor-pointer p-0" %>
    </div>
  </div>
</div>
