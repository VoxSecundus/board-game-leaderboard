<div class="bg-white dark:bg-gray-800 rounded-lg shadow overflow-hidden hover:shadow-md transition-shadow">
  <% if game.box_art.attached? %>
    <%= image_tag game.box_art.variant(resize_to_fit: [400, 200]),
        class: "w-full h-40 object-contain bg-gray-100 dark:bg-gray-700 p-2",
        alt: game.name %>
  <% else %>
    <div class="w-full h-40 bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
      <span class="text-8xl font-light text-gray-300 dark:text-gray-600 select-none">?</span>
    </div>
  <% end %>

  <div class="p-4">
    <div class="flex items-start justify-between gap-2">
      <div class="min-w-0">
        <%= link_to game.name, game_path(game),
            class: "text-base font-bold text-gray-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 leading-tight" %>
        <% if game.bgg_url.present? %>
          <p class="mt-1">
            <%= link_to "BoardGameGeek", game.bgg_url,
                target: "_blank", rel: "noopener noreferrer",
                class: "text-xs text-indigo-600 dark:text-indigo-400 hover:underline" %>
          </p>
        <% end %>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Added <%= game.created_at.to_date %></p>
      </div>

      <div class="flex items-center gap-1 flex-shrink-0">
        <%= link_to edit_game_path(game),
            title: "Edit",
            class: "p-1.5 rounded text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
        <% end %>
        <%= button_to game_path(game), method: :delete,
            title: "Delete",
            data: { turbo_confirm: "Delete #{game.name}?" },
            class: "p-1.5 rounded text-gray-400 hover:text-red-600 dark:hover:text-red-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors bg-transparent border-0 cursor-pointer" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</div>
