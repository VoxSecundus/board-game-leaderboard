<% content_for :title, "Games" %>
<% breadcrumbs(["Home", root_path], ["Games", nil]) %>

<div data-controller="view-toggle">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white">Games</h1>
    <div class="flex items-center gap-3">
      <button data-action="view-toggle#showGrid" data-view-toggle-target="gridBtn"
              class="p-2 rounded-md text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
              aria-label="Grid view">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/>
        </svg>
      </button>
      <button data-action="view-toggle#showTable" data-view-toggle-target="tableBtn"
              class="p-2 rounded-md text-gray-500 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors"
              aria-label="Table view">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>
        </svg>
      </button>
      <%= link_to "Import from BGG", bgg_import_games_path,
          class: "rounded-md border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 text-sm font-semibold py-2 px-4 transition-colors" %>
      <%= link_to "New Game", new_game_path,
          class: "rounded-md bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2 px-4 transition-colors" %>
    </div>
  </div>

  <% if @pending_imports.any? %>
    <div class="mb-6 rounded-md bg-indigo-50 dark:bg-indigo-900/20 border border-indigo-200 dark:border-indigo-800 px-4 py-3 text-sm text-indigo-700 dark:text-indigo-300 flex items-center gap-2">
      <svg class="h-4 w-4 shrink-0 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      <span>
        Importing BGG collection<%= @pending_imports.many? ? "s" : "" %> for
        <%= safe_join(@pending_imports.map { |i| content_tag(:strong, i.username) }, ", ") %>&thinsp;—
        games will appear once the import finishes.
      </span>
    </div>
  <% end %>

  <%= render "shared/search_form", url: games_path, label: "Search games by name" %>

  <% if @games.empty? %>
    <div class="text-center py-16 text-gray-500 dark:text-gray-400">
      <% if @query.present? %>
        <p class="text-lg">No games match "<%= @query %>".</p>
      <% else %>
        <p class="text-lg mb-4">No games yet.</p>
        <%= link_to "Add the first game", new_game_path, class: "text-indigo-600 dark:text-indigo-400 hover:underline" %>
      <% end %>
    </div>
  <% else %>
    <div data-view-toggle-target="gridView" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
      <%= render @games %>
    </div>

    <div data-view-toggle-target="tableView" class="hidden overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-800">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              <%= sortable_link("name", "Name") %>
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              <%= sortable_link("created_at", "Added") %>
            </th>
            <th scope="col" class="px-6 py-3 text-right text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              Actions
            </th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
          <% @games.each do |game| %>
            <tr data-controller="navigate" data-navigate-url-value="<%= game_path(game) %>"
                data-action="click->navigate#go"
                class="cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800/50">
              <td class="px-6 py-4 whitespace-nowrap">
                <div class="flex items-center gap-3">
                  <% if game.box_art.attached? %>
                    <div data-controller="thumbnail" class="relative w-8 h-8 shrink-0 rounded bg-gray-100 dark:bg-gray-700">
                      <span data-thumbnail-target="placeholder" class="absolute inset-0 flex items-center justify-center text-xs font-light text-gray-300 dark:text-gray-600 select-none" aria-hidden="true">?</span>
                      <%= image_tag game.box_art.variant(resize_to_fit: [64, 64]),
                          class: "absolute inset-0 w-full h-full rounded object-contain invisible",
                          data: { thumbnail_target: "image", action: "load->thumbnail#show error->thumbnail#error" },
                          alt: "#{game.name} box art" %>
                    </div>
                  <% else %>
                    <div class="w-8 h-8 shrink-0 rounded bg-gray-100 dark:bg-gray-700 flex items-center justify-center">
                      <span class="text-xs font-light text-gray-300 dark:text-gray-600 select-none" aria-hidden="true">?</span>
                    </div>
                  <% end %>
                  <%= link_to game.name, game_path(game),
                      class: "text-sm font-medium text-gray-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400" %>
                </div>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500 dark:text-gray-400">
                <%= game.created_at.to_date %>
              </td>
              <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                <div class="flex items-center justify-end gap-2">
                  <%= link_to edit_game_path(game),
                      title: "Edit",
                      class: "p-1.5 rounded text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                    </svg>
                  <% end %>
                  <%= button_to game_path(game), method: :delete,
                      title: "Delete",
                      data: { turbo_confirm: "Delete #{game.name}?" },
                      class: "p-1.5 rounded text-gray-400 hover:text-red-600 dark:hover:text-red-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors bg-transparent border-0 cursor-pointer" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
                    </svg>
                  <% end %>
                  <% bgg = safe_external_url(game.bgg_url) %>
                  <% if bgg %>
                    <%= link_to bgg, target: "_blank", rel: "noopener noreferrer",
                        title: "View on BoardGameGeek",
                        class: "p-1.5 rounded text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                    <% end %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if @pagy.pages > 1 %>
      <div class="mt-6 flex justify-center">
        <%== @pagy.series_nav %>
      </div>
    <% end %>
  <% end %>
</div>
