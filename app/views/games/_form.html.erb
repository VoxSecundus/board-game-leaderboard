<%= render "shared/errors", record: game %>

<%= form_with model: game, class: "space-y-6" do |f| %>
  <div>
    <%= f.label :name, "Name", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.text_field :name,
        autofocus: game.new_record?,
        class: "block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
  </div>

  <div>
    <%= f.label :bgg_url, "BoardGameGeek URL", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= f.url_field :bgg_url,
        placeholder: "https://boardgamegeek.com/boardgame/...",
        class: "block w-full rounded-md border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-800 text-gray-900 dark:text-white px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-1 focus:ring-indigo-500" %>
    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Optional.</p>
  </div>

  <div>
    <%= f.label :box_art, "Box Art", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <% if game.box_art.attached? %>
      <div class="mb-3">
        <%= image_tag game.box_art.variant(resize_to_fit: [160, 160]),
            class: "rounded object-contain bg-gray-100 dark:bg-gray-700 p-1",
            alt: game.name %>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Current image. Upload a new one to replace it.</p>
      </div>
    <% end %>
    <%= f.file_field :box_art,
        accept: "image/jpeg,image/png,image/webp",
        class: "block w-full text-sm text-gray-500 dark:text-gray-400 file:mr-4 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 dark:file:bg-indigo-900/50 dark:file:text-indigo-300 hover:file:bg-indigo-100" %>
    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">JPEG, PNG, or WebP. Max 5 MB. Optional.</p>
  </div>

  <div class="flex items-center gap-3">
    <%= f.submit game.new_record? ? "Create Game" : "Update Game",
        class: "rounded-md bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold py-2 px-4 transition-colors cursor-pointer" %>
    <%= link_to "Cancel",
        game.new_record? ? games_path : game_path(game),
        class: "text-sm font-medium text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white" %>
  </div>
<% end %>
