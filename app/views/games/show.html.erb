<% content_for :title, @game.name %>
<% breadcrumbs(["Home", root_path], ["Games", games_path], [@game.name, nil]) %>

<div class="bg-white dark:bg-gray-800 rounded-lg shadow p-6 max-w-2xl">
  <div class="flex items-start gap-6">
    <% if @game.box_art.attached? %>
      <div class="flex-shrink-0" data-controller="image-modal">
        <button type="button"
                data-action="click->image-modal#open"
                class="block cursor-zoom-in rounded focus:outline-none focus-visible:ring-2 focus-visible:ring-indigo-500">
          <%= image_tag @game.box_art.variant(resize_to_fit: [96, 96]),
              class: "rounded object-contain bg-gray-100 dark:bg-gray-700 p-1",
              width: 96, height: 96, alt: @game.name %>
        </button>

        <dialog data-image-modal-target="dialog"
                data-action="click->image-modal#backdropClick"
                class="m-auto rounded-lg shadow-xl backdrop:bg-black/60 p-0 max-w-[90vw] max-h-[90vh] bg-transparent">
          <div class="relative">
            <%= image_tag url_for(@game.box_art),
                class: "block max-w-[90vw] max-h-[90vh] object-contain rounded-lg",
                alt: @game.name %>
            <button type="button"
                    data-action="click->image-modal#close"
                    class="absolute top-2 right-2 rounded-full bg-black/50 text-white w-8 h-8 flex items-center justify-center text-lg leading-none hover:bg-black/70"
                    aria-label="Close">
              &times;
            </button>
          </div>
        </dialog>
      </div>
    <% end %>
    <div class="flex-1 min-w-0">
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white"><%= @game.name %></h1>
      <% bgg = safe_external_url(@game.bgg_url) %>
      <% if bgg %>
        <p class="mt-2">
          <%= link_to "View on BoardGameGeek", bgg,
              target: "_blank", rel: "noopener noreferrer",
              class: "text-sm text-indigo-600 dark:text-indigo-400 hover:underline" %>
        </p>
      <% end %>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">Added <%= @game.created_at.to_date %></p>
    </div>
    <div class="flex items-center gap-3 flex-shrink-0">
      <%= link_to "Edit", edit_game_path(@game),
          class: "text-sm font-medium text-indigo-600 dark:text-indigo-400 hover:underline" %>
      <%= button_to "Delete", game_path(@game), method: :delete,
          data: { turbo_confirm: "Delete #{@game.name}?" },
          class: "text-sm font-medium text-red-600 dark:text-red-400 hover:underline bg-transparent border-0 cursor-pointer p-0" %>
    </div>
  </div>
</div>

<div class="mt-8">
  <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">Play History</h2>
  <% if @plays.empty? %>
    <p class="text-sm text-gray-500 dark:text-gray-400">No plays recorded for this game yet.</p>
  <% else %>
    <div class="overflow-x-auto">
      <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-700">
        <thead class="bg-gray-50 dark:bg-gray-800">
          <tr>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              <%= sortable_link("date", "Date") %>
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">
              <%= sortable_link("location", "Location") %>
            </th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Players</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Winner(s)</th>
            <th scope="col" class="px-6 py-3 text-left text-xs font-medium text-gray-500 dark:text-gray-400 uppercase tracking-wider">Notes</th>
          </tr>
        </thead>
        <tbody class="bg-white dark:bg-gray-900 divide-y divide-gray-200 dark:divide-gray-700">
          <% @plays.each do |play| %>
            <%= render "plays/history_row", play: play %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
