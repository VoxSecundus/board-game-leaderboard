# Copy to .env and fill in values. Never commit .env.

# Required: bcrypt hash of the login password. Generate with:
#   rails runner "puts BCrypt::Password.create('your-password')"
# APP_PASSWORD=

# Required for local dev: secret key for signing cookies/sessions. Generate with:
#   rails secret
# SECRET_KEY_BASE=

# Optional: set to production when running via Docker
# RAILS_ENV=production

# BGG XML API bearer token (required for Fetch from BGG feature)
# BGG_API_TOKEN=
